# Email Configuration
# Note: For Gmail, use an App Password instead of your normal password
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
IMAP_SERVER=imap.gmail.com

# Allowed Senders (comma separated, no spaces)
# Only emails from these addresses will be processed
ALLOWED_SENDERS=sender1@example.com,sender2@example.com

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_LINKEDIN=your_second_gemini_api_key_here

# X (Twitter) API Configuration
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_SECRET=your_x_access_secret_here
X_COOKIE_AUTH_TOKEN=your_auth_token_here

OPENCODE_API_KEY=your_opencode_api_key_here
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
